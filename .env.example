# Tokens de Truecaller (múltiples cuentas - separados por comas)
TRUECALLER_TOKENS=token1,token2,token3

# Lista de proxies (formato: http://user:pass@ip:port)
PROXY_LIST=http://user1:pass1@proxy1:8080,http://user2:pass2@proxy2:8080

# Configuración de caché
CACHE_TTL=86400
CACHE_FILE=./cache.json

# Modo offline
OFFLINE_MODE=false
